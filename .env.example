# Utilisé par docker-compose.yml pour le service postgres et injecté dans apps/api
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=copilote_ia_business
POSTGRES_PORT=5432

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/copilote_ia_business?schema=public

JWT_ACCESS_SECRET=change-me-access-secret-min-16-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-16-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

API_PORT=3000
CORS_ORIGIN=http://localhost:5173

# Optionnel : sans cette clé, l'API démarre normalement mais les routes /copilot
# renvoient 503. Obtenez une clé sur https://console.anthropic.com
ANTHROPIC_API_KEY=

VITE_API_URL=http://localhost:3000/api
